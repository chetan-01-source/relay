    "/api/v1/platform/orgs": {
      "post": {
        "summary": "Onboard a new organization (Logto org + entitlements + admin invite)",
        "tags": ["tenancy"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 200
                  },
                  "adminEmail": {
                    "type": "string",
                    "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
                  },
                  "template": {
                    "type": "string",
                    "enum": ["default", "trial", "internal"]
