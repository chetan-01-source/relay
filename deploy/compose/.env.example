# === infra (docker compose) ===
POSTGRES_PASSWORD=change-me-locally
RELAY_APP_PASSWORD=change-me-locally
MINIO_ROOT_USER=relay
MINIO_ROOT_PASSWORD=change-me-locally

# === relay-server (RELAY_* validated by platform/config zod schema at boot) ===
# runtime: RLS-bound non-superuser role (uses RELAY_APP_PASSWORD)
RELAY_DATABASE_URL=postgres://relay_app:change-me-locally@localhost:5432/relay
# migrations: superuser role, same DB (uses POSTGRES_PASSWORD) — CREATE/FORCE RLS/CREATE POLICY
RELAY_MIGRATION_DATABASE_URL=postgres://postgres:change-me-locally@localhost:5432/relay
RELAY_VALKEY_URL=redis://localhost:6379
RELAY_MASTER_KEY=                       # generate: openssl rand -base64 32  (envelope-crypto KEK)
RELAY_LOGTO_ENDPOINT=http://localhost:3001
RELAY_LOGTO_M2M_APP_ID=                 # filled by `make seed-auth` (sprint Day 5)
RELAY_LOGTO_M2M_APP_SECRET=
RELAY_LOGTO_JWT_AUDIENCE=https://relay.gateway/api  # control-plane JWT audience (Day 6, ADR 0002)
RELAY_BOOTSTRAP_ADMIN_EMAIL=you@example.com
RELAY_MINIO_ENDPOINT=http://localhost:9000
RELAY_MINIO_ACCESS_KEY=relay
RELAY_MINIO_SECRET_KEY=change-me-locally

# Day-11 value layer. Exact response cache (Valkey): TTL 0 = disabled; bodies over the cap aren't cached.
RELAY_CACHE_TTL_S=0
RELAY_CACHE_MAX_BYTES=262144
# Metering: bounded in-process ring queue flushed to Postgres; hourly rollups recomputed on an interval.
RELAY_METERING_QUEUE_MAX=10000
RELAY_METERING_FLUSH_INTERVAL_MS=2000
RELAY_ROLLUP_INTERVAL_MS=60000
