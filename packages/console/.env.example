# Console Logto sign-in (Traditional web app). Copy to .env.local and fill.
# The Logto app's redirect URI must be ${LOGTO_BASE_URL}/callback.
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=http://localhost:3000
LOGTO_COOKIE_SECRET=   # openssl rand -base64 24

# Control-plane API client (FE-1). Where the gateway's /api/* lives + the Relay API resource the
# access token is minted for (must match RELAY_LOGTO_JWT_AUDIENCE on the server).
RELAY_API_BASE_URL=http://localhost:3000
RELAY_API_RESOURCE=https://relay.gateway/api
