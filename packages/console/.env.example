# Console Logto sign-in (Traditional web app). Copy to .env.local and fill.
# The console dev server runs on :3100 (the gateway owns :3000 — its data plane, /docs, /v1/*).
# The Logto app's redirect URI must match ${LOGTO_BASE_URL}/callback, i.e. http://localhost:3100/callback.
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=http://localhost:3100
LOGTO_COOKIE_SECRET=   # openssl rand -base64 24

# Control-plane API client (FE-1). Where the gateway's /api/* lives (the GATEWAY on :3000, not the
# console) + the Relay API resource the access token is minted for (must match
# RELAY_LOGTO_JWT_AUDIENCE on the server).
RELAY_API_BASE_URL=http://localhost:3000
RELAY_API_RESOURCE=https://relay.gateway/api
