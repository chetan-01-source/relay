{
  "name": "@relay/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "relay": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage",
    "dev": "tsx watch src/cli/index.ts serve"
  },
  "dependencies": {
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@relay/shared": "workspace:*",
    "commander": "^15.0.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
