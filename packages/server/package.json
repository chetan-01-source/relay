    "dev": "tsx watch src/cli/index.ts serve"
  },
  "dependencies": {
    "@relay/shared": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
