{
  "name": "@relay/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "relay": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --clean",
    "typecheck": "tsc --noEmit",
